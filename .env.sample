# ==================== LLM (MiniMax via OpenAI-compatible API) ====================
MINIMAX_API_KEY=your-minimax-api-key
LLM_MODEL=MiniMax-M2.5
# 当前代码使用 langchain_openai.ChatOpenAI，MiniMax 需走 /v1 兼容接口，不用 /anthropic
LLM_BASE_URL=https://api.minimax.io/v1

# ==================== 图片生成 (12ai Gemini 代理) ====================
IMAGEN_API_KEY=your-imagen-api-key
IMAGEN_MODEL=gemini-3.1-flash-image-preview
IMAGEN_BASE_URL=https://new.12ai.org
IMAGEN_IMAGE_SIZE=1K
IMAGEN_NUMBER_OF_IMAGES=1
GEMINI_API_KEY=

# ==================== 新闻搜索 ====================
NEWS_API_KEY=your-newsapi-key

# ==================== 本地启动默认端口 ====================
BACKEND_PORT=18000
FRONTEND_PORT=15173
POSTGRES_PORT=15432
REDIS_PORT=16379

# ==================== 数据库 (本地/宿主机) ====================
DATABASE_URL=postgresql+asyncpg://postgres:password@127.0.0.1:15432/masppt
REDIS_URL=redis://127.0.0.1:16379/0

# ==================== Docker Compose 内部服务名（无需改动，compose 会自动覆盖） ====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=masppt

# ==================== 认证 ====================
JWT_SECRET_KEY=your-super-secret-key-change-in-production

# ==================== 应用配置 ====================
APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:15173,http://127.0.0.1:15173,http://localhost:5173,http://127.0.0.1:5173

# ==================== huashu-slides 集成 ====================
SKILL_SCRIPTS_DIR=./huashu-slides/scripts/
STYLE_SAMPLES_DIR=./huashu-slides/assets/style-samples/
RENDER_PATH_DEFAULT=auto
