# ==================== 数据库 ====================
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/masppt
REDIS_URL=redis://redis:6379/0

# ==================== 认证 ====================
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== 大模型 API ====================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ==================== 应用配置 ====================
APP_ENV=development
DEBUG=true
WORKER_QUEUE_POLL_INTERVAL_SECONDS=1.0
WORKER_JOB_STALE_SECONDS=120
WORKER_JOB_HEARTBEAT_SECONDS=15
OBJECT_STORAGE_BACKEND=local
OBJECT_STORAGE_LOCAL_ROOT=object_storage
OBJECT_STORAGE_PUBLIC_BASE_URL=http://localhost:8000/api/v1/assets
OBJECT_STORAGE_BUCKET=masppt-assets
OBJECT_STORAGE_ENDPOINT_URL=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_SECURE=false
ASSET_RETENTION_HOURS=168
ASSET_CLEANUP_INTERVAL_SECONDS=300
ASSET_CLEANUP_BATCH_SIZE=100

# ==================== PostgreSQL (docker-compose 使用) ====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=masppt
