# ==================== 环境 ====================
APP_ENV=staging
DEBUG=false

# ==================== 数据库 ====================
DATABASE_URL=postgresql+asyncpg://staging_user:change-me@staging-postgres:5432/masppt_staging
REDIS_URL=redis://staging-redis:6379/0

# ==================== 认证 ====================
JWT_SECRET_KEY=replace-with-a-staging-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== 大模型 API ====================
OPENAI_API_KEY=sk-staging-openai-key
GEMINI_API_KEY=staging-gemini-key

# ==================== Worker ====================
WORKER_QUEUE_POLL_INTERVAL_SECONDS=1.0
WORKER_JOB_STALE_SECONDS=120
WORKER_JOB_HEARTBEAT_SECONDS=15

# ==================== 对象存储 ====================
OBJECT_STORAGE_BACKEND=s3
OBJECT_STORAGE_PUBLIC_BASE_URL=https://staging-api.example.com/api/v1/assets
OBJECT_STORAGE_BUCKET=masppt-staging-assets
OBJECT_STORAGE_ENDPOINT_URL=https://minio-staging.example.com
OBJECT_STORAGE_ACCESS_KEY=replace-with-staging-access-key
OBJECT_STORAGE_SECRET_KEY=replace-with-staging-secret-key
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_SECURE=true

# ==================== 资产保留 ====================
ASSET_RETENTION_HOURS=168
ASSET_CLEANUP_INTERVAL_SECONDS=300
ASSET_CLEANUP_BATCH_SIZE=100
